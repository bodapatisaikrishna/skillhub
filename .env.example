# SkillHub environment variables.
# Copy to .env.local for local dev (.env.local is gitignored — never commit secrets).

# --- GitHub metadata sync (/api/sync) ---
# Optional. A fine-grained PAT with public-repo read access.
# Without it the sync uses the unauthenticated GitHub API (60 requests/hour),
# which is enough for a small seed but will rate-limit as the catalog grows.
# This token is read server-side only and is never exposed to the client.
GITHUB_TOKEN=

# Optional. If set, /api/sync requires `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron sends this header automatically when the env var is configured.
CRON_SECRET=

# --- Live-metadata store (stars + last-updated, written by /api/sync) ---
# Optional but recommended in production. When these are set, the cache uses
# Vercel KV (a shared store every page lambda reads), so the daily sync's star
# counts actually show up site-wide. Connecting a Vercel KV / Upstash store to
# the project injects both vars automatically — you usually don't set them by
# hand. Without them, the cache falls back to a per-instance temp file (fine for
# local dev; on Vercel it's per-lambda so cron writes won't be visible to pages).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Public config (safe to expose; inlined into the client bundle) ---
# Canonical site URL, used for SEO/OG tags, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://skillhub.dev

# owner/repo that the submission form opens prefilled issues against.
NEXT_PUBLIC_SUBMIT_REPO=your-org/skillhub
